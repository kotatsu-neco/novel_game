    },
    "water_corridor": {
      "kind": "image",
      "src": "content/assets/bg/water_corridor.webp",
      "position": "center center",
      "overlay": "dark_vignette"
    },
    "kiosk": {
      "kind": "image",
      "src": "content/assets/bg/kiosk.webp",
      "position": "center center",
      "overlay": "dark_vignette"
    },
    "cafe": {
      "kind": "image",
