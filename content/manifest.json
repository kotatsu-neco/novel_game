{
  "title": "迷路",
  "version": "maze-loop-v05-speed-slider",
  "entryScenario": "content/scenario/main.json",
  "engine": "sn_engine_v02d_speed_slider",
  "gameId": "maze",
  "saveKey": "maze_save_loop_v05",
  "assetPolicy": "Background PNG files from the source package were converted to WebP and resized for lighter private test use. Audio remains unset/silent unless later replaced. Runtime scenario refactored to routeCheck/mazeLoopCount loop control.",
  "requiredFiles": [
    "index.html",
    "src/main.js",
    "styles/base.css",
    "content/scenario/main.json",
    "content/assets/bg/"
  ],
  "engineUiPolicy": {
    "screenScroll": "disabled",
    "textWindowScroll": "disabled",
    "advanceTapArea": "whole_stage_except_buttons_choices_panel",
    "pagination": "strict_wrapped_lines_with_japanese_kinsoku",
    "typewriter": {
      "enabled": true,
      "tapWhileTyping": "show_full_page",
      "tapAfterComplete": "advance_page_or_step",
      "defaultPreset": {
        "text": 2,
        "voice": 2,
        "document": 2
      },
      "speedSlider": {
        "enabled": true,
        "min": 0,
        "max": 4,
        "default": 2,
        "labels": [
          "とてもゆっくり",
          "ゆっくり",
          "標準",
          "速い",
          "瞬時"
        ]
      }
    },
    "fontSize": {
      "defaultPreset": {
        "text": "normal",
        "voice": "normal",
        "document": "normal"
      },
      "presets": [
        "small",
        "normal",
        "large"
      ]
    },
    "textLayoutEngine": {
      "manualPages": true,
      "inlineCommands": {
        "[r]": "lineBreak",
        "[p]": "pageBreak"
      },
      "autoPagination": true,
      "kinsoku": true,
      "backlogKindEntries": true
    },
    "loopControl": {
      "stateKeys": [
        "mazeLoopCount",
        "lastLoopCause"
      ],
      "stepType": "routeCheck",
      "choiceEffects": [
        "increment",
        "set",
        "score"
      ]
    }
  },
  "contentPack": {
    "formatVersion": "1.0",
    "runtimeScenario": "content/scenario/main.json",
    "storyBible": "content/scenario/STORY_BIBLE.md",
    "scenarioSource": "content/scenario/SCENARIO_SOURCE.md",
    "backgroundAssignment": "content/scenario/BACKGROUND_ASSIGNMENT.md",
    "assetReport": "content/scenario/ASSET_REPORT.md",
    "sourceReport": "content/scenario/SOURCE_REPORT.md",
    "loopRefactorReport": "content/scenario/LOOP_REFACTOR_REPORT.md",
    "originalScenarioSource": "content/scenario/ORIGINAL_SCENARIO_SOURCE_BEFORE_LOOP_REFACTOR.md",
    "wordingRevisionReport": "content/scenario/WORDING_REVISION_REPORT.md",
    "openingDepthRevisionReport": "content/scenario/OPENING_DEPTH_REVISION_REPORT.md",
    "uiChoiceCanonFixReport": "content/scenario/UI_CHOICE_CANON_FIX_REPORT.md"
  },
  "backgrounds": {
    "station_stairs": {
      "kind": "image",
      "src": "content/assets/bg/station_stairs.webp",
      "position": "center center",
      "overlay": "dark_vignette"
    },
    "maze_corridor": {
      "kind": "image",
      "src": "content/assets/bg/maze_corridor.webp",
      "position": "center center",
      "overlay": "dark_vignette"
    },
    "crossroad": {
