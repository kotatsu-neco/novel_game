{
  "title": "迷路",
  "version": "maze-webp-mount-v01",
  "entryScenario": "content/scenario/main.json",
  "engine": "sn_engine_v02a",
  "gameId": "maze",
  "saveKey": "maze_save_webp_v01",
  "assetPolicy": "Background PNG files from the source package were converted to WebP and resized for lighter private test use. Audio remains unset/silent unless later replaced.",
  "requiredFiles": [
    "index.html",
    "src/main.js",
    "styles/base.css",
    "content/scenario/main.json",
    "content/assets/bg/"
  ],
  "engineUiPolicy": {
    "screenScroll": "disabled",
    "textWindowScroll": "disabled",
    "advanceTapArea": "whole_stage_except_buttons_choices_panel",
    "pagination": "strict_wrapped_lines_with_japanese_kinsoku",
    "typewriter": {
      "enabled": true,
      "tapWhileTyping": "show_full_page",
      "tapAfterComplete": "advance_page_or_step",
      "defaultPreset": {
        "text": "normal",
        "voice": "normal",
        "document": "normal"
      }
    },
    "fontSize": {
      "defaultPreset": {
        "text": "normal",
        "voice": "normal",
        "document": "normal"
      },
      "presets": [
        "small",
        "normal",
        "large"
      ]
    },
    "textLayoutEngine": {
      "manualPages": true,
      "inlineCommands": {
        "[r]": "lineBreak",
        "[p]": "pageBreak"
      },
      "autoPagination": true,
      "kinsoku": true,
      "backlogKindEntries": true
    }
  },
  "contentPack": {
    "formatVersion": "1.0",
    "runtimeScenario": "content/scenario/main.json",
    "storyBible": "content/scenario/STORY_BIBLE.md",
    "scenarioSource": "content/scenario/SCENARIO_SOURCE.md",
    "backgroundAssignment": "content/scenario/BACKGROUND_ASSIGNMENT.md",
    "assetReport": "content/scenario/ASSET_REPORT.md",
    "sourceReport": "content/scenario/SOURCE_REPORT.md"
  },
  "backgrounds": {
