{
  "title": "返し鈴",
  "version": "v1.9",
  "entryScenario": "content/scenario/main.json",
  "engine": "html-js-minimal",
  "assetPolicy": "Scene backgrounds are included as local PNG files. Audio remains Web Audio placeholder tones in v0.2.",
  "requiredFiles": [
    "index.html",
    "src/main.js",
    "styles/base.css",
    "content/scenario/main.json",
    "assets/bg/"
  ],
  "engineUiPolicy": {
    "screenScroll": "disabled",
    "textWindowScroll": "disabled",
    "advanceTapArea": "whole_stage_except_buttons_choices_panel",
    "pagination": "strict_wrapped_lines_with_japanese_kinsoku",
    "cssSplitFuturePlan": "styles/base.css will be split into engine.css and theme.css in a later version",
    "paginationProfile": {
      "document": {
        "charsPerLine": 18,
        "maxLines": 12
      },
      "voice": {
        "charsPerLine": 20,
        "maxLines": 7
      },
      "text": {
        "charsPerLine": 20,
        "maxLines": 10
      }
    },
    "typewriter": {
      "enabled": true,
      "tapWhileTyping": "show_full_page",
      "tapAfterComplete": "advance_page_or_step",
      "speedsMsPerChar": {
        "text": 35,
        "voice": 45,
        "document": 12,
        "title": 0
      },
      "futureSettingCandidates": [
        "standard",
        "fast",
        "instant"
      ]
    },
    "viewportHeightPolicy": "prefer_100svh_for_mobile_safari",
    "saveLoad": {
      "storesCurrentStepLoggedKey": true,
      "doesNotStoreTypewriterCharacterIndex": true
    },
    "kinsoku": {
      "avoidLineStart": [
        "、",
        "。",
        "，",
        "．",
        ",",
        ".",
        "！",
        "？",
        "!",
        "?",
        "」",
        "』",
        "）",
        "】",
        "〕",
        "〉",
        "》",
        "」"
      ],
      "avoidPunctuationOnlyLine": true
    },
    "textLayoutEngine": {
      "manualPages": true,
      "inlineCommands": {
        "[r]": "lineBreak",
        "[p]": "pageBreak"
      },
      "reservedCommands": {
        "[l]": "clickWaitWithoutClear_future"
      },
      "autoPagination": true,
      "kinsoku": true,
      "backlogKindEntries": true
    }
  },
  "authoringSystem": {
    "enabled": true,
    "runtimeReads": [
      "content/manifest.json",
      "content/scenario/main.json"
    ],
    "runtimeDoesNotRead": [
      "content/scenario/STORY_BIBLE.md",
      "content/scenario/SCENARIO_SOURCE.md",
      "docs/AI_SCENARIO_RULES.md",
      "docs/HUMAN_MANUAL.md"
    ],
    "sourceAuthorityOrder": [
      "content/scenario/STORY_BIBLE.md",
      "content/scenario/SCENARIO_SOURCE.md locked/human_final",
      "SPEC.md",
      "DESIGN.md",
      "docs/TEXT_GUIDE.md",
      "current task request",
      "AI suggestions"
    ],
    "statusFlow": [
      "draft",
      "ai_revise",
      "human_review",
      "human_final",
      "locked"
    ],
    "futureCompiler": "SCENARIO_SOURCE.md to main.json compiler is not implemented in v1.6",
    "contentPackReady": true,
    "lastSyncedRuntimeVersion": "v1.6-docfix",
    "compilerImplemented": true,
    "compilerPath": "tools/compile_scenario.py",
    "compileReport": "content/scenario/COMPILE_REPORT.md",
    "sourceMetadataEnabled": true
  },
  "gameId": "kaeshisuzu",
  "saveKey": "kaeshisuzu_save_v01",
  "contentPack": {
    "formatVersion": "1.0",
    "runtimeScenario": "content/scenario/main.json",
    "storyBible": "content/scenario/STORY_BIBLE.md",
    "scenarioSource": "content/scenario/SCENARIO_SOURCE.md",
    "compileReport": "content/scenario/COMPILE_REPORT.md",
    "themeCss": "styles/theme.css",
    "engineCss": "styles/engine.css",
    "docfix": "v1.6-docfix",
    "compiler": "tools/compile_scenario.py",
    "sourceMetadata": "content/scenario/SCENARIO_SOURCE.md"
  },
  "backgrounds": {
    "black_rain": {
      "kind": "cssClass",
      "className": "bg-black_rain"
    },
    "black_plain": {
      "kind": "cssClass",
      "className": "bg-black_plain"
    },
    "old_house_evening": {
      "kind": "image",
      "src": "assets/bg/old_house_evening.png"
    },
    "butsuma_night": {
      "kind": "image",
      "src": "assets/bg/butsuma_night.png"
    },
    "mountain_path": {
      "kind": "image",
      "src": "assets/bg/mountain_path.png"
    },
    "shrine_night": {
      "kind": "image",
      "src": "assets/bg/shrine_night.png"
    },
    "shrine_dawn": {
      "kind": "image",
      "src": "assets/bg/shrine_dawn.png"
    },
    "old_house_morning": {
      "kind": "image",
      "src": "assets/bg/old_house_morning.png"
    },
    "butsuma_morning": {
      "kind": "image",
      "src": "assets/bg/butsuma_morning.png"
    }
  },
  "audio": {
    "ambiences": {},
    "se": {}
  }
}
